# Local Docker Compose defaults (development only — not for production).
# Used automatically when `.env` is missing (e.g. `./scripts/tmux-docker.sh`).
# Override anything by creating your own `.env` in the repo root.
#
# If Postgres fails with "password authentication failed" after changing this file,
# reset the volume: docker compose --env-file docker/dev.env down -v

POSTGRES_USER=chess
POSTGRES_DB=chess
POSTGRES_PASSWORD=dev

ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_WS_URL=http://127.0.0.1:4001
