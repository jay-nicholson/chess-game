# Copy to `.env` on the homeserver next to docker-compose.yml

# --- Postgres (required by docker-compose.yml) ---
POSTGRES_USER=chess
POSTGRES_DB=chess
POSTGRES_PASSWORD=change-me-long-random

# --- Socket.IO CORS: browser origins that may load the UI ---
# Example: https://chess.example.com
ALLOWED_ORIGINS=https://chess.example.com

# --- Baked into the Next.js client at image build time ---
# Must be the public URL players use to reach the game server (https / wss as appropriate).
# Example: https://ws.example.com
NEXT_PUBLIC_WS_URL=https://ws.example.com

# --- Optional: protect /health on game-server for monitors ---
# GAME_SERVER_HEALTH_KEY=

# --- Optional: protect Next.js /admin (see src/middleware.ts) ---
# ADMIN_SECRET=

# --- Optional tuning (defaults match docker-compose.yml) ---
# RATE_LIMIT_PER_MINUTE=80
# FIDGET_RATE_LIMIT_PER_MINUTE=40
# REDIS_URL=redis://redis:6379
